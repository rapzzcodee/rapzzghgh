<!-- NOW PLAYING BAR — di body level agar position:fixed selalu nempel layar -->
<div class="czm-npbar" id="czm-npbar" onclick="czmOpenPlayer()">
  <div class="czm-np-prog"><div class="czm-np-fill" id="czm-np-fill"></div></div>
  <img class="czm-np-thumb" id="czm-np-thumb" src="" alt="">
  <div class="czm-np-info">
    <div class="czm-np-title-clip"><div class="czm-np-title" id="czm-np-title">—</div></div>
    <div class="czm-np-artist" id="czm-np-artist">—</div>
  </div>
  <div class="czm-np-ctrl">
    <button class="czm-np-btn" onclick="event.stopPropagation();czmPrev()"><i class="fa-solid fa-backward-step"></i></button>
    <button class="czm-np-btn" id="czm-np-play" onclick="event.stopPropagation();czmToggle()"><i class="fa-solid fa-play" id="czm-np-ico"></i></button>
    <button class="czm-np-btn" onclick="event.stopPropagation();czmNext()"><i class="fa-solid fa-forward-step"></i></button>
  </div>
</div>

<!-- PLAYLIST MODAL — di dalam section#music, z-index di atas player (10003) -->
<div id="czm-plm-ov" onclick="czmClosePlm()" style="display:none;position:fixed;inset:0;background:rgba(15,32,53,0.6);z-index:10025;"></div>
<div id="czm-plm-modal" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:10026;background:#1a2d42;border-radius:16px 16px 0 0;max-height:85vh;overflow:hidden;flex-direction:column;transform:translateY(100%);transition:transform .28s cubic-bezier(.32,.72,0,1);">

<!-- Pilih Playlist Bottom Sheet -->
  <div style="display:flex;justify-content:center;padding:10px 0 4px;flex-shrink:0;">
    <div style="width:36px;height:4px;background:rgba(255,255,255,.18);border-radius:2px;"></div>
  </div>
  <div style="display:flex;align-items:center;justify-content:space-between;padding:4px 18px 12px;border-bottom:1px solid rgba(255,255,255,.07);flex-shrink:0;">
    <span style="font-size:16px;font-weight:700;color:#fff;"><i class="fa-solid fa-music" style="color:#00d9ff;margin-right:8px;"></i>Playlist Saya</span>
    <button onclick="czmClosePlm()" style="background:none;border:none;color:#aaa;font-size:20px;cursor:pointer;padding:4px;"><i class="fa-solid fa-xmark"></i></button>
  </div>
  <div style="padding:12px 18px;border-bottom:1px solid rgba(255,255,255,.07);flex-shrink:0;display:flex;gap:10px;align-items:center;">
    <input id="czm-plm-new" placeholder="Nama playlist baru..." style="flex:1;background:#152840;border:1px solid rgba(255,255,255,.2);border-radius:10px;padding:10px 14px;color:#fff;font-size:14px;outline:none;">
    <button onclick="czmCreatePl()" style="background:#00C4E6;border:none;color:#fff;border-radius:10px;padding:10px 16px;font-size:14px;font-weight:700;cursor:pointer;white-space:nowrap;flex-shrink:0;"><i class="fa-solid fa-plus"></i> Buat</button>
  </div>
  <div id="czm-plm-list" style="overflow-y:auto;flex:1;padding:6px 0;"></div>
</div>
<div id="czm-plm-detail" style="display:none;position:fixed;inset:0;z-index:10027;background:#0f2035;flex-direction:column;">
  <div style="display:flex;align-items:center;gap:12px;padding:14px 14px 14px;border-bottom:1px solid rgba(255,255,255,.07);flex-shrink:0;background:#0f2035;">
    <button onclick="czmClosePlDetail()" style="background:none;border:none;color:#aaa;font-size:20px;cursor:pointer;padding:4px;"><i class="fa-solid fa-arrow-left"></i></button>
    <span id="czm-plm-dname" style="font-size:16px;font-weight:700;flex:1;color:#fff;"></span>
    <button onclick="czmDeletePl()" style="background:none;border:none;color:#ff4444;font-size:14px;cursor:pointer;padding:4px 8px;"><i class="fa-solid fa-trash"></i></button>
  </div>
  <div id="czm-plm-dsongs" style="flex:1;overflow-y:auto;padding:6px 0;"></div>
</div>

<div id="czm-plpick-ov" onclick="czmClosePlPick()" style="display:none;position:fixed;inset:0;background:rgba(7,15,26,0.65);z-index:10030;backdrop-filter:blur(3px);"></div>
<div id="czm-plpick-sheet" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:10031;background:#1e3248;border-radius:16px 16px 0 0;overflow:hidden;flex-direction:column;transform:translateY(100%);transition:transform .28s cubic-bezier(.32,.72,0,1);max-height:80vh;box-shadow:0 -4px 40px rgba(0,0,0,0.6);">
  <!-- Handle -->
  <div style="display:flex;justify-content:center;padding:10px 0 6px;flex-shrink:0;">
    <span style="width:36px;height:4px;background:rgba(255,255,255,.2);border-radius:2px;display:block;"></span>
  </div>
  <!-- Header -->
  <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 20px 14px;border-bottom:1px solid rgba(255,255,255,.08);flex-shrink:0;">
    <span style="font-size:16px;font-weight:700;color:#fff;">Pilih Playlist</span>
    <button onclick="czmClosePlPick()" style="background:rgba(255,255,255,0.08);border:none;color:#aaa;font-size:16px;cursor:pointer;padding:6px 10px;border-radius:8px;line-height:1;"><i class="fa-solid fa-xmark"></i></button>
  </div>
  <!-- List -->
  <div id="czm-plpick-list" style="overflow-y:auto;flex:1;"></div>
  <!-- Batal -->
  <div onclick="czmClosePlPick()" style="text-align:center;padding:16px;font-size:15px;font-weight:600;color:#aaa;cursor:pointer;border-top:1px solid rgba(255,255,255,.07);flex-shrink:0;letter-spacing:0.3px;">Batal</div>
</div>



<!-- ── Lightbox Modal ── -->
<div class="zt-lightbox" id="zt-lightbox">
  <div class="zt-lightbox-overlay" onclick="ztLightboxClose()"></div>
  <div class="zt-lightbox-counter" id="zt-lb-counter"></div>
  <button class="zt-lightbox-close" onclick="ztLightboxClose()"><i class="fas fa-times"></i></button>
  <button class="zt-lightbox-nav zt-lightbox-prev" id="zt-lb-prev" onclick="ztLightboxNav(-1)"><i class="fas fa-chevron-left"></i></button>
  <button class="zt-lightbox-nav zt-lightbox-next" id="zt-lb-next" onclick="ztLightboxNav(1)"><i class="fas fa-chevron-right"></i></button>
  <div class="zt-lightbox-inner">
    <img class="zt-lightbox-img" id="zt-lb-img" src="" alt="" onclick="this.classList.toggle('zoomed')">
  </div>
  <div class="zt-lightbox-bottom">
    <a id="zt-lb-save" class="zt-lightbox-btn save" download target="_blank"><i class="fas fa-download"></i> Simpan</a>
    <a id="zt-lb-open" class="zt-lightbox-btn open" target="_blank"><i class="fas fa-external-link-alt"></i> Buka Tab</a>
  </div>
</div>

<!-- ═══════════════ CPANEL SECTION ═══════════════ -->
<section id="cpanel" class="page-section cpanel-page">

  <!-- Header -->
  <div class="cpanel-header">
    <div class="cpanel-header-glow"></div>
    <h1 class="cpanel-title">Create <span class="cpanel-accent">Pterodactyl</span></h1>
    <p class="cpanel-subtitle">Create Server Pterodactyl Secara Gratis. Ingin List Lebih Banyak? Aktifkan Pengguna Premium Anda.</p>
  </div>

  <!-- Tab Switcher -->
  <div class="cp-tab-bar">
    <div class="cp-tab active" id="cp-tab-form" onclick="cpSwitchTab('form')">
      <i class="fas fa-plus-circle"></i> Buat Panel
    </div>
    <div class="cp-tab" id="cp-tab-riwayat" onclick="cpSwitchTab('riwayat')">
      <i class="fas fa-history"></i> Riwayat
      <span id="cp-riwayat-tab-count" class="cp-riwayat-tab-count" style="display:none;"></span>
    </div>
  </div>

  <!-- TAB: Form Create -->
  <div id="cp-tab-panel-form">
  <!-- Form Create -->
  <div class="cpanel-form-box" style="position:relative;">
    <!-- Badge Premium (pojok kanan atas) -->
    <div id="cp-prem-badge" class="cp-prem-badge" onclick="cpOpenPremInfo()" style="display:none;">
      <i class="fas fa-crown"></i> Premium
    </div>

    <div class="cpanel-username-label"><i class="fas fa-user"></i> Username Panel</div>
    <input type="text" id="cp-username" placeholder="contoh: zain123" autocomplete="off" style="width:100%;box-sizing:border-box;background:rgba(255,255,255,0.05);border:1px solid rgba(0,217,255,0.2);border-radius:10px;padding:11px 14px;color:#fff;font-size:13px;outline:none;margin-bottom:16px;">

    <!-- Plan Selector -->
    <div class="cpanel-plan-label"><i class="fas fa-layer-group"></i> Pilih Plan</div>

    <!-- FREE plans vertical -->
    <div class="cpanel-plans-v" id="cp-plans-free">
      <!-- Divider non premium -->
      <div class="cp-plans-divider cp-plans-divider-free">
        <span><i class="fas fa-user" style="color:#00d9ff;margin-right:5px;font-size:10px;"></i>Plan Gratis</span>
      </div>
      <div class="cpanel-plan-v" data-plan="1" data-free="1" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name">1 GB</div><div class="cpv-specs">RAM 1GB • CPU 30%</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
      <div class="cpanel-plan-v" data-plan="2" data-free="1" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name">2 GB</div><div class="cpv-specs">RAM 2GB • CPU 60%</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
      <!-- Tombol Premium -->
      <div class="cpanel-plan-prem-btn" onclick="cpShowTokenInput()" id="cp-arrow-card">
        <i class="fas fa-crown" style="color:#ffaa00;font-size:18px;"></i>
        <div class="cpv-left" style="flex:1;">
          <div class="cpv-name" style="color:#ffaa00;">Premium</div>
          <div class="cpv-specs">Buka plan 3GB – Unli</div>
        </div>
        <i class="fas fa-chevron-right cpanel-arrow-icon" style="color:#ffaa00;font-size:13px;transition:transform 0.3s;"></i>
      </div>
    </div>

    <!-- Premium plans (hidden sampai token benar) -->
    <div id="cp-plans-prem" class="cpanel-plans-v" style="display:none;margin-top:4px;">
      <!-- Divider premium -->
      <div class="cp-plans-divider">
        <span><i class="fas fa-crown" style="color:#ffaa00;margin-right:5px;font-size:10px;"></i>Plan Premium</span>
      </div>
      <div class="cpanel-plan-v" data-plan="3" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name">3 GB</div><div class="cpv-specs">RAM 3GB • CPU 90%</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
      <div class="cpanel-plan-v" data-plan="4" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name">4 GB</div><div class="cpv-specs">RAM 4GB • CPU 110%</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
      <div class="cpanel-plan-v" data-plan="5" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name">5 GB</div><div class="cpv-specs">RAM 5GB • CPU 140%</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
      <div class="cpanel-plan-v" data-plan="6" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name">6 GB</div><div class="cpv-specs">RAM 6GB • CPU 170%</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
      <div class="cpanel-plan-v" data-plan="7" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name">7 GB</div><div class="cpv-specs">RAM 7GB • CPU 200%</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
      <div class="cpanel-plan-v" data-plan="8" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name">8 GB</div><div class="cpv-specs">RAM 8GB • CPU 230%</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
      <div class="cpanel-plan-v" data-plan="9" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name">9 GB</div><div class="cpv-specs">RAM 9GB • CPU 260%</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
      <div class="cpanel-plan-v" data-plan="10" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name">10 GB</div><div class="cpv-specs">RAM 10GB • CPU 290%</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
      <div class="cpanel-plan-v" data-plan="11" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name">11 GB</div><div class="cpv-specs">RAM 11GB • CPU 320%</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
      <div class="cpanel-plan-v" data-plan="12" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name">12 GB</div><div class="cpv-specs">RAM 12GB • CPU 360%</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
      <div class="cpanel-plan-v cpanel-plan-v-unli" data-plan="unli" onclick="cpSelectPlan(this)">
        <div class="cpv-left"><div class="cpv-name" style="color:#ffaa00;">∞ Unli</div><div class="cpv-specs">Unlimited semua</div></div>
        <i class="fas fa-check cpv-check"></i>
      </div>
    </div>

    <!-- Create Button -->
    <button class="cpanel-create-btn" id="cp-create-btn" onclick="cpCreatePanel()">
      <i class="fas fa-plus-circle"></i> Buat Panel
    </button>

  </div>
  </div><!-- end cp-tab-panel-form -->

  <!-- TAB: Riwayat -->
  <div id="cp-tab-panel-riwayat" style="display:none;">
    <div class="cp-riwayat-panel">
      <div class="cp-riwayat-panel-header">
        <span id="cp-history-counter" class="cp-history-counter"></span>
      </div>
      <div id="cp-history-list" class="cpanel-history-list"></div>
    </div>
  </div>

  <!-- Floating Token Modal -->
  <div id="cp-token-modal" class="cpanel-token-modal" style="display:none;" onclick="cpCloseTokenModal(event)">
    <div class="cpanel-token-float">
      <div class="cpanel-token-float-header">
        <div style="display:flex;align-items:center;gap:8px;">
          <i class="fas fa-crown" style="color:#ffaa00;font-size:16px;"></i>
          <span style="font-weight:800;color:#fff;font-size:15px;">Aktifkan Premium</span>
        </div>
        <button onclick="document.getElementById('cp-token-modal').style.display='none'" style="background:rgba(255,255,255,0.08);border:none;color:#aaa;font-size:16px;cursor:pointer;padding:6px 10px;border-radius:8px;"><i class="fas fa-times"></i></button>
      </div>
      <p style="font-size:12px;color:rgba(255,255,255,0.5);margin:0 0 14px;">Masukkan token premium untuk membuka plan 3GB hingga Unlimited.</p>
      <div class="cpanel-lock-input-wrap">
        <input type="password" id="cp-prem-code" placeholder="Masukan Kata Kunci Token..." class="cpanel-lock-input" onkeydown="if(event.key==='Enter')cpCheckCode()">
        <button class="cpanel-lock-submit" onclick="cpCheckCode()"><i class="fas fa-unlock"></i></button>
      </div>
      <div id="cp-code-status" class="cpanel-code-status"></div>
      <div class="cpanel-lock-divider">Belum punya token?</div>
      <a href="https://wa.me/6285713164894?text=Halo%20PretyFX69%2C%20saya%20mau%20beli%20token%20premium%20panel%20Pterodactyl"
         target="_blank" class="cpanel-wa-btn">
        <i class="fab fa-whatsapp"></i> Beli Token di PretyFX69
      </a>
    </div>
  </div>

  <!-- Modal Info Premium -->
  <div id="cp-prem-info-modal" class="cpanel-token-modal" style="display:none;" onclick="cpClosePremInfo(event)">
    <div class="cpanel-token-float">
      <div class="cpanel-token-float-header">
        <div style="display:flex;align-items:center;gap:8px;">
          <i class="fas fa-crown" style="color:#ffaa00;font-size:18px;"></i>
          <span style="font-weight:800;color:#fff;font-size:16px;">Status Premium</span>
        </div>
        <button onclick="document.getElementById('cp-prem-info-modal').style.display='none'" style="background:rgba(255,255,255,0.08);border:none;color:#aaa;font-size:16px;cursor:pointer;padding:6px 10px;border-radius:8px;"><i class="fas fa-times"></i></button>
      </div>
      <div class="cp-prem-info-body">
        <div class="cp-prem-info-icon">👑</div>
        <div class="cp-prem-info-title">Kamu Sudah Premium!</div>
        <div class="cp-prem-info-desc">Semua plan dari 3GB hingga Unlimited sudah terbuka. Riwayat pembuatan panel kamu juga nggak ada batasnya — bebas bikin sebanyak apapun.</div>
        <div class="cp-prem-info-perks">
          <div class="cp-perm-perk"><i class="fas fa-check-circle" style="color:#22c55e"></i> Plan 3GB – 12GB + Unlimited</div>
          <div class="cp-perm-perk"><i class="fas fa-check-circle" style="color:#22c55e"></i> Riwayat panel unlimited</div>
          <div class="cp-perm-perk"><i class="fas fa-check-circle" style="color:#22c55e"></i> Akses penuh tanpa batas</div>
        </div>
      </div>
      <button class="cp-prem-logout-btn" onclick="cpLogoutPremium()">
        <i class="fas fa-sign-out-alt"></i> Logout Premium
      </button>
    </div>
  </div>

</section>

<!-- cPanel Result Modal -->
<div id="cp-result-modal" class="cpanel-result-modal" style="display:none;" onclick="cpCloseResultModal(event)">
  <div id="cp-result" class="cpanel-result"></div>
</div>

<!-- CZ Custom Confirm Modal -->
<div id="cz-confirm-overlay">
  <div id="cz-confirm-box">
    <div id="cz-confirm-icon"><i class="fas fa-trash-alt"></i></div>
    <div id="cz-confirm-title">Konfirmasi Hapus</div>
    <div id="cz-confirm-msg"></div>
    <div class="cz-confirm-btns">
      <button id="cz-confirm-cancel"><i class="fas fa-times"></i> Batal</button>
      <button id="cz-confirm-ok"><i class="fas fa-trash"></i> Hapus</button>
    </div>
  </div>
</div>
<script src="script.js"></script>
</body>
</html>
