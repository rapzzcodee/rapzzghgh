    <!-- WIKIPEDIA -->
    <div id="zt-wiki" class="zt-panel">
      <div class="zt-search-box">
        <input id="zt-wiki-input" type="text" placeholder="Cari artikel Wikipedia..." onkeydown="if(event.key==='Enter')ztSearchWiki()">
        <button onclick="ztSearchWiki()"><i class="fas fa-search"></i></button>
      </div>
      <!-- Multi-bahasa -->
      <div class="zt-wiki-langs-wrap"><div class="zt-wiki-langs">
        <button class="zt-wiki-lang-btn active" onclick="ztSetLang('id',this)"><span class="zt-flag">🇮🇩</span> Indonesia</button>
        <button class="zt-wiki-lang-btn" onclick="ztSetLang('en',this)"><span class="zt-flag">🇬🇧</span> English</button>
        <button class="zt-wiki-lang-btn" onclick="ztSetLang('ja',this)"><span class="zt-flag">🇯🇵</span> 日本語</button>
        <button class="zt-wiki-lang-btn" onclick="ztSetLang('ar',this)"><span class="zt-flag">🇸🇦</span> العربية</button>
        <button class="zt-wiki-lang-btn" onclick="ztSetLang('fr',this)"><span class="zt-flag">🇫🇷</span> Français</button>
        <button class="zt-wiki-lang-btn" onclick="ztSetLang('de',this)"><span class="zt-flag">🇩🇪</span> Deutsch</button>
        <button class="zt-wiki-lang-btn" onclick="ztSetLang('ko',this)"><span class="zt-flag">🇰🇷</span> 한국어</button>
        <button class="zt-wiki-lang-btn" onclick="ztSetLang('zh',this)"><span class="zt-flag">🇨🇳</span> 中文</button>
      </div></div>
      <!-- Reader modal -->
      <div id="zt-wiki-reader" class="zt-wiki-reader" style="display:none;">
        <div class="zt-wiki-reader-header">
          <button class="zt-wiki-reader-back" onclick="ztWikiCloseReader()"><i class="fas fa-arrow-left"></i></button>
          <span id="zt-wiki-reader-title">Wikipedia</span>
          <a id="zt-wiki-reader-ext" href="#" target="_blank"><i class="fas fa-external-link-alt"></i></a>
        </div>
        <div id="zt-wiki-reader-body" class="zt-wiki-reader-body"></div>
        <!-- Floating back button fallback -->
        <button onclick="ztWikiCloseReader()" style="position:fixed;bottom:28px;right:20px;z-index:10001;width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,#00d9ff,#0099cc);border:none;color:#000;font-size:18px;box-shadow:0 4px 20px rgba(0,217,255,0.5);cursor:pointer;">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div id="zt-wiki-result" class="zt-result-area"></div>
    </div>

    <!-- RANDOM ANIME -->
    <div id="zt-anime" class="zt-panel">
      <div class="zt-anime-cats">
        <button class="zt-cat-btn active" onclick="ztSetAnimeCat('waifu',this)">Waifu</button>
        <button class="zt-cat-btn" onclick="ztSetAnimeCat('neko',this)">Neko</button>
        <button class="zt-cat-btn" onclick="ztSetAnimeCat('shinobu',this)">Shinobu</button>
        <button class="zt-cat-btn" onclick="ztSetAnimeCat('megumin',this)">Megumin</button>
        <button class="zt-cat-btn" onclick="ztSetAnimeCat('cuddle',this)">Cuddle</button>
        <button class="zt-cat-btn" onclick="ztSetAnimeCat('hug',this)">Hug</button>
        <button class="zt-cat-btn" onclick="ztSetAnimeCat('pat',this)">Pat</button>
        <button class="zt-cat-btn" onclick="ztSetAnimeCat('blush',this)">Blush</button>
      </div>
      <div id="zt-anime-result" class="zt-anime-result">
        <div class="zt-anime-placeholder">
          <i class="fas fa-image"></i>
          <p>Tekan tombol untuk generate gambar anime random!</p>
        </div>
      </div>
      <button class="zt-gen-btn" onclick="ztRandomAnime()">
        <i class="fas fa-random"></i> Generate Random
      </button>
    </div>

    <!-- CEK NOMOR HP -->
    <div id="zt-phone" class="zt-panel">
      <div class="zt-search-box">
        <input id="zt-phone-input" type="tel" placeholder="Contoh: 0812345678910" onkeydown="if(event.key==='Enter')ztCheckPhone()">
        <button onclick="ztCheckPhone()"><i class="fas fa-search"></i></button>
      </div>
      <div id="zt-phone-result" class="zt-result-area"></div>
    </div>

    <!-- TIKTOK DOWNLOAD -->
    <div id="zt-tiktok" class="zt-panel active">
      <div class="zt-dl-box">
        <div class="zt-dl-icon"><i class="fab fa-tiktok"></i></div>
        <h3 class="zt-dl-title">Download TikTok</h3>
        <p class="zt-dl-desc">Video &amp; Foto tanpa watermark</p>
</div>
        <div class="zt-search-box">
          <input id="zt-tiktok-input" type="url" placeholder="Paste link TikTok di sini..." onkeydown="if(event.key==='Enter')ztDownload('tiktok')">
          <button onclick="ztDownload('tiktok')"><i class="fas fa-download"></i></button>
        </div>
        <div class="zt-fmt-btns">
          <button class="zt-fmt active" onclick="ztSetFmt(this,'mp4')">📹 MP4</button>
          <button class="zt-fmt" onclick="ztSetFmt(this,'mp3')">🎵 MP3</button>
        </div>
        <div id="zt-tiktok-result" class="zt-result-area"></div>
      </div>
    </div>

    <!-- INSTAGRAM DOWNLOAD -->
    <div id="zt-instagram" class="zt-panel">
      <div class="zt-dl-box">
        <div class="zt-dl-icon" style="background:linear-gradient(135deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888)"><i class="fab fa-instagram"></i></div>
        <h3 class="zt-dl-title">Download Instagram</h3>
        <p class="zt-dl-desc">Reels, Post, Story</p>
        </div>
        <div class="zt-search-box">
          <input id="zt-ig-input" type="url" placeholder="Paste link Instagram di sini..." onkeydown="if(event.key==='Enter')ztDownload('ig')">
          <button onclick="ztDownload('ig')"><i class="fas fa-download"></i></button>
        </div>
        <div class="zt-fmt-btns">
          <button class="zt-fmt active" onclick="ztSetFmt(this,'mp4')">📹 MP4</button>
          <button class="zt-fmt" onclick="ztSetFmt(this,'mp3')">🎵 MP3</button>
        </div>
        <div id="zt-ig-result" class="zt-result-area"></div>
      </div>
    </div>

    <!-- NGAJI -->
    <div id="zt-ngaji" class="zt-panel">
      <div class="zt-ngaji-wrap">

        <!-- ② PLAYER — di atas sebelum list -->
        <div class="zt-ngaji-player" id="zt-ngaji-player">
          <div class="zt-ngp-inner">
            <!-- Now playing info -->
            <div class="zt-ngp-now">
              <div class="zt-ngp-disc" id="zt-ngp-disc"><i class="fas fa-quran"></i></div>
              <div class="zt-ngp-txt">
                <div class="zt-ngp-surah-name" id="zt-ngp-name">—</div>
                <div class="zt-ngp-surah-arab" id="zt-ngp-arab">—</div>
                <div class="zt-ngp-meta" id="zt-ngp-meta">—</div>
              </div>
              <div class="zt-eq paused" id="zt-ngp-eq">
                <div class="zt-eq-bar"></div><div class="zt-eq-bar"></div>
                <div class="zt-eq-bar"></div><div class="zt-eq-bar"></div>
                <div class="zt-eq-bar"></div>
              </div>
            </div>

            <!-- Custom progress -->
            <div class="zt-ngp-progress-wrap">
              <div class="zt-ngp-time-row">
                <span class="zt-ngp-time-cur" id="zt-ngp-cur">0:00</span>
                <span class="zt-ngp-time-dur" id="zt-ngp-dur">0:00</span>
              </div>
              <div class="zt-ngp-track" id="zt-ngp-track" onclick="ztNgpSeek(event)">
                <div class="zt-ngp-fill" id="zt-ngp-fill"></div>
              </div>
            </div>

            <!-- Controls -->
            <div class="zt-ngp-controls">
              <button class="zt-ngp-btn" id="zt-ngp-prev" onclick="ztNgajiPrev()"><i class="fas fa-step-backward"></i> Prev</button>
              <button class="zt-ngp-playpause" id="zt-ngp-pp" onclick="ztNgpToggle()"><i class="fas fa-play" id="zt-ngp-pp-icon"></i></button>
              <button class="zt-ngp-btn" id="zt-ngp-next" onclick="ztNgajiNext()">Next <i class="fas fa-step-forward"></i></button>
            </div>
          </div>
        </div>

        <!-- ③ Search -->
        <div class="zt-ngaji-search-wrap">
          <div class="zt-ngaji-search">
            <input id="zt-ngaji-search" type="text" placeholder="&#x1F50D; Cari nama surah..." oninput="ztNgajiFilter(this.value)">
            <button class="zt-ngaji-search-clear" onclick="ztNgajiClear()"><i class="fas fa-times"></i> Reset</button>
          </div>
        </div>

        <!-- ④ Daftar Surah — floating cards, no outer box -->
        <div class="zt-surah-section-label">114 Surah</div>
        <div class="zt-surah-list-wrap" id="zt-surah-list"></div>

        <!-- Hidden audio -->
        <audio id="zt-ngaji-audio" preload="none"
          onplay="ztNgpPlay()" onpause="ztNgpPause()"
          ontimeupdate="ztNgpTick()" onloadedmetadata="ztNgpMeta()"
          onended="ztNgajiNext()"></audio>

      </div>
    </div>

    <!-- IP &amp; LOKASI PANEL -->
    <!-- Backend URL hardcoded, tombol settings dihapus -->

    <div id="zt-ip" class="zt-panel">
      <div class="zt-ip-wrap">

        <div class="zt-ip-mycard">
          <div class="zt-ip-mycard-header">
            <div class="zt-ip-pulse"></div>
            <span>IP Kamu Saat Ini</span>
          </div>
          <div id="zt-ip-mine">
            <div class="zt-loading"><i class="fas fa-spinner fa-spin"></i> Mendeteksi IP...</div>
          </div>
        </div>

      </div>
    </div>

    <!-- FILE TO URL PANEL -->
    <div id="zt-fileurl" class="zt-panel">

      <!-- Header -->
      <div class="zt-dl-box">
        <div class="zt-va-icon"><i class="fas fa-file"></i><i class="fas fa-arrow-right zt-va-arrow"></i><i class="fas fa-link"></i></div>
        <h3 class="zt-dl-title">File to URL</h3>
        <p class="zt-dl-desc">Upload simpan foto/video lalu ubah menjadi link</p>
      </div>

      <!-- Tab switcher -->
      <div class="zt-fu-tabs">
        <button class="zt-fu-tab active" id="zt-fu-tab-upload" onclick="ztFuSwitchTab('upload')">
          <i class="fas fa-upload"></i> Upload
        </button>
        <button class="zt-fu-tab" id="zt-fu-tab-history" onclick="ztFuSwitchTab('history')">
          <i class="fas fa-history"></i> Riwayat
          <span class="zt-fu-hist-badge" id="zt-fu-hist-badge" style="display:none"></span>
        </button>
      </div>

      <!-- UPLOAD VIEW -->
      <div id="zt-fu-view-upload">
        <div class="zt-fu-dropzone" id="zt-fu-dropzone"
          onclick="document.getElementById('zt-fu-input').click()"
          ondragover="ztFuDragOver(event)" ondragleave="ztFuDragLeave(event)" ondrop="ztFuDrop(event)">
          <i class="fas fa-cloud-upload-alt zt-fu-drop-icon"></i>
          <div class="zt-fu-drop-text">Klik atau drag &amp; drop file di sini</div>
          <div class="zt-fu-drop-hint">Foto (JPG PNG GIF WEBP) · Video (MP4 MOV MKV AVI) · Max 25MB</div>
          <input id="zt-fu-input" type="file"
            accept="image/jpeg,image/png,image/gif,image/webp,image/bmp,video/mp4,video/quicktime,video/x-matroska,video/x-msvideo,video/webm,video/3gpp"
            style="display:none" onchange="ztFuSelected(this)">
        </div>

        <div id="zt-fu-preview-wrap" style="display:none" class="zt-fu-preview-wrap">
          <div id="zt-fu-preview-inner"></div>
          <div class="zt-fu-meta" id="zt-fu-meta"></div>
        </div>

        <button class="zt-fu-upload-btn" id="zt-fu-btn" onclick="ztFuUpload()" style="display:none">
          <i class="fas fa-upload"></i> Upload &amp; Dapat URL
        </button>

        <div id="zt-fu-progress-wrap" style="display:none" class="zt-fu-progress-wrap">
          <div class="zt-fu-bar-track"><div class="zt-fu-bar" id="zt-fu-bar"></div></div>
          <div class="zt-fu-bar-label" id="zt-fu-bar-label">Uploading...</div>
        </div>

        <div id="zt-fu-result" class="zt-fu-result" style="display:none">
          <div class="zt-fu-result-label"><i class="fas fa-check-circle"></i> Berhasil!</div>
          <div class="zt-fu-url-wrap">
            <input id="zt-fu-url" class="zt-fu-result-url" readonly>
            <button class="zt-fu-copy-btn" onclick="ztFuCopy()" id="zt-fu-copy-btn"><i class="fas fa-copy"></i></button>
          </div>
          <div class="zt-fu-actions">
            <a id="zt-fu-open" href="#" target="_blank" class="zt-fu-action-btn"><i class="fas fa-external-link-alt"></i> Buka</a>
            <button class="zt-fu-action-btn" onclick="ztFuReset()"><i class="fas fa-redo"></i> Upload Lagi</button>
          </div>
        </div>
      </div>

      <!-- HISTORY VIEW -->
      <div id="zt-fu-view-history" style="display:none">
        <div id="zt-fu-hist-empty" class="zt-fu-hist-empty">
          <i class="fas fa-inbox"></i>
          <div>Belum ada riwayat upload</div>
        </div>
        <div class="zt-fu-hist-top" id="zt-fu-hist-top" style="display:none">
          <span class="zt-fu-hist-count" id="zt-fu-hist-count"></span>
        </div>
        <div id="zt-fu-history" class="zt-fu-history"></div>
      </div>

    </div>

    <!-- SPEED TEST PANEL -->
    <div id="zt-speedtest" class="zt-panel">
      <div class="zt-speed-wrap">

        <!-- Header -->
        <div class="zt-speed-hero">
          <div class="zt-speed-hero-icon">
            <i class="fas fa-tachometer-alt"></i>
          </div>
          <h3 class="zt-speed-hero-title">Internet Speed Test</h3>
          <p class="zt-speed-hero-desc">Ukur kecepatan internet kamu secara akurat</p>
        </div>

        <!-- Gauges -->
        <div class="zt-speed-gauges-wrap">
          <div class="zt-speed-gauge-box">
            <div class="zt-speed-gauge-icon" style="color:#22c55e"><i class="fas fa-arrow-down"></i></div>
            <div class="zt-speed-gauge-val" id="zt-speed-dl">—</div>
            <div class="zt-speed-gauge-unit">Mbps</div>
            <div class="zt-speed-gauge-label">Download</div>
          </div>
          <div class="zt-speed-gauge-sep"></div>
          <div class="zt-speed-gauge-box">
            <div class="zt-speed-gauge-icon" style="color:#fbbf24"><i class="fas fa-bolt"></i></div>
            <div class="zt-speed-gauge-val" id="zt-speed-ping">—</div>
            <div class="zt-speed-gauge-unit">ms</div>
            <div class="zt-speed-gauge-label">Ping</div>
          </div>
          <div class="zt-speed-gauge-sep"></div>
          <div class="zt-speed-gauge-box">
            <div class="zt-speed-gauge-icon" style="color:#a855f7"><i class="fas fa-server"></i></div>
            <div class="zt-speed-gauge-val" id="zt-speed-jitter">—</div>
            <div class="zt-speed-gauge-unit">ms</div>
            <div class="zt-speed-gauge-label">Jitter</div>
          </div>
        </div>

        <!-- Progress bar -->
        <div class="zt-speed-bar-outer" id="zt-speed-bar-wrap" style="display:none">
          <div class="zt-speed-bar-track">
            <div class="zt-speed-bar-fill" id="zt-speed-bar"></div>
          </div>
        </div>

        <!-- Status text -->
        <div id="zt-speed-status" class="zt-speed-status-text"></div>

        <!-- Start button -->
        <button class="zt-speed-start-btn" id="zt-speed-btn" onclick="ztSpeedTest()">
          <i class="fas fa-play"></i> Mulai Test
        </button>

        <!-- Rating -->
        <div id="zt-speed-rating" class="zt-speed-rating" style="display:none"></div>

        <!-- History -->
        <div id="zt-speed-history" class="zt-speed-history"></div>

      </div>
    </div>

    <!-- IMAGE SEARCH PANEL -->
    <div id="zt-imgsearch" class="zt-panel">
      <div class="zt-img-wrap">

        <div class="zt-search-box">
          <input id="zt-img-input" type="text" placeholder="Cari gambar... (gojo, aesthetic, nature)" onkeydown="if(event.key==='Enter')ztImgSearch()">
          <button onclick="ztImgSearch()"><i class="fas fa-search"></i></button>
        </div>
        <div id="zt-img-result" class="zt-img-result">
          <div class="zt-img-placeholder">
            <i class="fas fa-images"></i>
            <p>Cobalah Cari Gambar Sesuai Dengan Pemikiranmu Sendiri</p>
          </div>
        </div>
        <button id="zt-img-more" class="zt-img-more-btn" style="display:none" onclick="ztImgSearch(true)">
          <i class="fas fa-plus"></i> Muat Lebih Banyak
        </button>
      </div>
    </div>

    <!-- VIDEO TO AUDIO -->
    <div id="zt-videoaudio" class="zt-panel">
      <div class="zt-va-wrap">
        <div class="zt-va-hero">
          <div class="zt-va-icon"><i class="fas fa-film"></i><i class="fas fa-arrow-right zt-va-arrow"></i><i class="fas fa-music"></i></div>
          <h3 class="zt-va-title">Video to Audio</h3>
          <p class="zt-va-sub">Extract audio dari video yang kamu upload</p>
        </div>

        <!-- Dropzone -->
        <div class="zt-va-dropzone" id="zt-va-dropzone"
          onclick="document.getElementById('zt-va-input').click()"
          ondragover="ztVaDragOver(event)" ondragleave="ztVaDragLeave(event)" ondrop="ztVaDrop(event)">
          <i class="fas fa-cloud-upload-alt zt-va-drop-icon"></i>
          <div class="zt-va-drop-text">Klik atau drag & drop video di sini</div>
          <div class="zt-va-drop-hint">MP4 · MKV · AVI · MOV · WEBM</div>
          <input type="file" id="zt-va-input" accept="video/*" style="display:none" onchange="ztVaSelected(this)">
        </div>

        <!-- File info -->
        <div class="zt-va-fileinfo" id="zt-va-fileinfo" style="display:none">
          <i class="fas fa-file-video" style="color:#00d9ff;font-size:1.2rem;flex-shrink:0"></i>
          <div class="zt-va-fileinfo-text">
            <div class="zt-va-filename" id="zt-va-filename"></div>
            <div class="zt-va-filesize" id="zt-va-filesize"></div>
          </div>
          <button class="zt-va-clear-btn" onclick="ztVaReset()"><i class="fas fa-times"></i></button>
        </div>

        <!-- Format -->
        <div class="zt-va-options" id="zt-va-options" style="display:none">
          <div class="zt-va-opt-label"><i class="fas fa-file-audio"></i> Format Output: <strong style="color:#00fff6">MP3</strong></div>
        </div>

        <!-- Convert button -->
        <button class="zt-va-convert-btn" id="zt-va-convert-btn" onclick="ztVaConvert()" style="display:none">
          <i class="fas fa-magic"></i> Mulai Konversi
        </button>

        <!-- Progress -->
        <div class="zt-va-progress-wrap" id="zt-va-progress-wrap" style="display:none">
          <div class="zt-va-status" id="zt-va-status">Memuat ffmpeg...</div>
          <div class="zt-va-bar-track"><div class="zt-va-bar" id="zt-va-bar"></div></div>
          <div class="zt-va-bar-label" id="zt-va-bar-label">0%</div>
        </div>

        <!-- Result -->
        <div class="zt-va-result" id="zt-va-result" style="display:none">
          <div class="zt-va-result-icon"><i class="fas fa-check-circle"></i></div>
          <div class="zt-va-result-text">Konversi selesai!</div>
          <button class="zt-va-download-btn" id="zt-va-download-btn" onclick="ztVaDoDownload()">
            <i class="fas fa-download"></i> Download Audio
          </button>
          <button class="zt-va-again-btn" onclick="ztVaReset()">
            <i class="fas fa-redo"></i> Konversi Lagi
          </button>
        </div>

      </div>
    </div>

  </div>
</section>

<section id="ai" class="page-section">
<div class="container">
        <!-- Header -->
        <header class="header">
            <div class="header-content">
            </div>
        </header>

        <!-- Chat Container -->
        <div class="chat-container" id="chatContainer">
            <!-- Welcome Screen -->
            <div class="welcome-screen" id="welcomeScreen">
                <div class="welcome-hero">
                    <div class="hero-icon">
                        <i class="fa-solid fa-robot"></i>
                    </div>
                    <h1 class="hero-title">Selamat Datang di ZainAI</h1>
                    <p class="hero-subtitle">Asisten AI Cerdas Bertenaga VPS - Siap Membantu Anda</p>
                    <button id="helpBtn" onclick="openHelpModal()" style="
                        margin-top:14px;
                        padding:9px 20px;
                        border-radius:30px;
                        background:rgba(0,217,255,0.08);
                        border:1px solid rgba(0,217,255,0.3);
                        color:var(--primary-cyan);
                        font-size:13px;font-weight:600;
                        cursor:pointer;letter-spacing:0.04em;
                        display:inline-flex;align-items:center;gap:8px;
                        transition:all 0.2s ease;
                        animation:fadeInUp 0.5s cubic-bezier(.22,1,.36,1) 0.4s both;
                    ">
                        <i class="fa-solid fa-circle-question"></i> Lihat Semua Fitur
                    </button>
                </div>

                <div class="features-section">
                    <h3 class="section-title">Apa yang bisa saya bantu?</h3>
                    <div class="feature-grid">
                        <div class="feature-card" onclick="sendPrompt('Jelaskan tentang artificial intelligence dan machine learning')">
                            <i class="fa-solid fa-lightbulb feature-icon"></i>
                            <h4 class="feature-title">Pengetahuan</h4>
                            <p class="feature-desc">Pertanyaan umum &amp; edukasi</p>
                        </div>
                        <div class="feature-card" onclick="sendPrompt('Buatkan contoh kode Python untuk web scraping')">
                            <i class="fa-solid fa-code feature-icon"></i>
                            <h4 class="feature-title">Pemrograman</h4>
                            <p class="feature-desc">Coding &amp; debugging</p>
                        </div>
                        <div class="feature-card" onclick="sendPrompt('Buatkan cerita pendek tentang petualangan di luar angkasa')">
                            <i class="fa-solid fa-book feature-icon"></i>
                            <h4 class="feature-title">Kreativitas</h4>
                            <p class="feature-desc">Menulis &amp; brainstorming</p>
                        </div>
                        <div class="feature-card" onclick="sendPrompt('Analisis tren teknologi AI di tahun 2024')">
                            <i class="fa-solid fa-chart-line feature-icon"></i>
                            <h4 class="feature-title">Analisis</h4>
                            <p class="feature-desc">Data &amp; insights</p>
                        </div>
                        <div class="feature-card" onclick="sendPrompt('Berikan tips produktivitas untuk bekerja dari rumah')">
                            <i class="fa-solid fa-briefcase feature-icon"></i>
                            <h4 class="feature-title">Produktivitas</h4>
                            <p class="feature-desc">Tips &amp; strategi</p>
                        </div>
                        <div class="feature-card" onclick="sendPrompt('Jelaskan konsep blockchain dengan bahasa sederhana')">
                            <i class="fa-solid fa-graduation-cap feature-icon"></i>
                            <h4 class="feature-title">Pembelajaran</h4>
                            <p class="feature-desc">Tutorial &amp; panduan</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Input Area -->
        <div class="input-area">
            <div class="input-row">
                <button class="gear-btn" id="gearBtn" onclick="openSettings()" title="Settings">
                    <i class="fa-solid fa-gear"></i>
                </button>

                <div class="input-container">
                    <button class="attach-btn gear-inside" id="gearInside" onclick="openSettings()" title="Settings">
                        <i class="fa-solid fa-gear"></i>
                    </button>
                    <div class="input-wrapper">
                        <textarea 
                            id="userInput" 
                            placeholder="Balasan Untuk ZainAI" 
                            rows="1"
                            maxlength="2000"
                            onkeydown="handleKeyPress(event)"
                            oninput="autoResize(this)"
                        ></textarea>
                        <div class="char-counter" id="charCounter">0/2000</div>
                    </div>
                    <button id="sendBtn" onclick="sendMessage()" disabled title="Send Message">
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Help/Fitur Modal -->
    <div class="modal" id="helpModal" style="z-index:10001;align-items:flex-start;padding-top:70px;">
        <div class="modal-content" style="max-width:420px;max-height:82vh;overflow-y:auto;">
            <div class="modal-header" style="position:sticky;top:0;background:rgba(5,10,20,0.97);z-index:2;padding-bottom:12px;">
                <div style="display:flex;align-items:center;gap:10px;">
                    <i class="fa-solid fa-robot" style="color:var(--primary-cyan);font-size:20px;"></i>
                    <h3 class="modal-title" style="margin:0;">Fitur ZainAI</h3>
                </div>
                <button class="modal-close" id="helpModalClose" onclick="closeHelpModal()"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <div style="display:flex;flex-direction:column;gap:10px;margin-top:4px;">

                <!-- VidSnap -->
                <div class="help-feat-card">
                    <div class="help-feat-icon" style="background:rgba(255,80,80,0.12);color:#ff5555;">
                        <i class="fa-brands fa-youtube"></i>
                    </div>
                    <div class="help-feat-body">
                        <div class="help-feat-title">Download Video (VidSnap)</div>
                        <div class="help-feat-desc">Ketik <code>download [URL]</code> untuk download video YouTube / TikTok dalam format MP4, MP3, 720p, atau 1080p.</div>
                    </div>
                </div>

                <!-- Musik -->
                <div class="help-feat-card">
                    <div class="help-feat-icon" style="background:rgba(0,217,255,0.12);color:var(--primary-cyan);">
                        <i class="fa-solid fa-music"></i>
                    </div>
                    <div class="help-feat-body">
                        <div class="help-feat-title">Putar &amp; Kontrol Musik</div>
                        <div class="help-feat-desc">Ketik <code>putar [nama lagu]</code> untuk memutar musik. Bisa juga <code>pause</code>, <code>stop</code>, atau <code>lanjutkan</code> lewat chat.</div>
                    </div>
                </div>

                <!-- Mode Worm -->
                <div class="help-feat-card">
                    <div class="help-feat-icon" style="background:rgba(255,0,0,0.12);color:#ff3333;">
                        <i class="fa-solid fa-skull"></i>
                    </div>
                    <div class="help-feat-body">
                        <div class="help-feat-title">Mode Worm-AI</div>
                        <div class="help-feat-desc">Aktifkan di Pengaturan → Gaya Balasan → <b>Worm-AI</b>. AI jadi super kasar &amp; ngamuk. Khusus buat yang mau drama! 😈</div>
                    </div>
                </div>

                <!-- Singkat vs Riset -->
                <div class="help-feat-card">
                    <div class="help-feat-icon" style="background:rgba(100,200,255,0.1);color:#7bd4ff;">
                        <i class="fa-solid fa-brain"></i>
                    </div>
                    <div class="help-feat-body">
                        <div class="help-feat-title">Pola Berpikir</div>
                        <div class="help-feat-desc"><b>Singkat</b> → jawaban 2-3 kalimat langsung ke poin. <b>Riset Mendalam</b> → jawaban detail, lengkap, dengan heading &amp; contoh.</div>
                    </div>
                </div>

                <!-- Lokasi -->
                <div class="help-feat-card">
                    <div class="help-feat-icon" style="background:rgba(80,255,150,0.1);color:#4dffaa;">
                        <i class="fa-solid fa-location-dot"></i>
                    </div>
                    <div class="help-feat-body">
                        <div class="help-feat-title">Lokasi &amp; Info Cuaca</div>
                        <div class="help-feat-desc">ZainAI tahu lokasi kamu secara otomatis dan bisa kasih info cuaca, waktu setempat, serta rekomendasi berbasis lokasi.</div>
                    </div>
                </div>

                <!-- Mengaji -->
                <div class="help-feat-card">
                    <div class="help-feat-icon" style="background:rgba(255,200,80,0.12);color:#ffc850;">
                        <i class="fa-solid fa-moon"></i>
                    </div>
                    <div class="help-feat-body">
                        <div class="help-feat-title">Deteksi Mengaji</div>
                        <div class="help-feat-desc">ZainAI bisa mendeteksi konteks mengaji dari histori chat dan menyesuaikan respons agar lebih sopan &amp; relevan.</div>
                    </div>
                </div>

                <!-- Kode -->
                <div class="help-feat-card">
                    <div class="help-feat-icon" style="background:rgba(160,100,255,0.12);color:#b06bff;">
                        <i class="fa-solid fa-code"></i>
                    </div>
                    <div class="help-feat-body">
                        <div class="help-feat-title">Bantu Coding</div>
                        <div class="help-feat-desc">Minta buatin HTML/CSS/JS → otomatis digabung jadi 1 file. Tinggal copy-paste langsung jalan!</div>
                    </div>
                </div>

                <!-- Tips -->
                <div style="background:rgba(0,217,255,0.05);border:1px solid rgba(0,217,255,0.1);border-radius:12px;padding:12px 14px;font-size:11.5px;color:rgba(255,255,255,0.4);line-height:1.6;">
                    💡 <b style="color:rgba(0,217,255,0.6);">Tips:</b> Ketik <code>help</code> atau <code>fitur</code> di chat untuk lihat panduan ini via AI.
                </div>

            </div>
        </div>
    </div>

    <!-- Settings Modal -->
    <div class="modal" id="settingsModal">
        <div class="modal-overlay" onclick="closeSettings()"></div>
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">
                    <i class="fa-solid fa-sliders"></i>
                    Pengaturan
                </h2>
                <div style="display:flex;gap:8px;align-items:center;">
                    <button class="btn-icon" onclick="showInfo()" title="Info" style="width:30px;height:30px;border-radius:8px;font-size:13px;">
                        <i class="fa-solid fa-circle-info"></i>
                    </button>
                    <button class="close-btn" onclick="closeSettings()">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            </div>
            <div class="modal-body">
                <div class="settings-group">
                    <div class="api-server-notice">
                        <div class="api-marquee-wrap">
                            <div class="api-marquee-track">
                                <span>Kamu bisa memilih mode yang ada di bawah ini &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Kamu bisa memilih mode yang ada di bawah ini &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Kamu bisa memilih mode yang ada di bawah ini &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Kamu bisa memilih mode yang ada di bawah ini &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span><span>Kamu bisa memilih mode yang ada di bawah ini &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Kamu bisa memilih mode yang ada di bawah ini &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Kamu bisa memilih mode yang ada di bawah ini &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Kamu bisa memilih mode yang ada di bawah ini &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="settings-group">
                    <label class="settings-label"><i class="fa-solid fa-brain"></i> Pola Berpikir</label>
                    <div class="sett-row">
                        <div class="sett-pill" data-length="short" onclick="selectResponseLength('short')">
                            <i class="fa-solid fa-bolt"></i><span>Singkat</span>
                        </div>
                        <div class="sett-pill" data-length="long" onclick="selectResponseLength('long')">
                            <i class="fa-solid fa-magnifying-glass"></i><span>Riset Mendalam</span>
                        </div>
                    </div>
                </div>
                <div class="settings-group">
                    <label class="settings-label"><i class="fa-solid fa-comments"></i> Gaya Balasan</label>
                    <div class="sett-row">
                        <div class="sett-pill active" data-style="neutral" onclick="selectResponseStyle('neutral')">
                            <i class="fa-solid fa-cube"></i><span>Normal</span>
                        </div>
                        <div class="sett-pill sett-pill-danger" data-style="angry" onclick="selectResponseStyle('angry')">
                            <i class="fa-solid fa-skull"></i><span>Worm-AI</span>
                        </div>
                    </div>
                </div>
                <div class="settings-group" style="margin-bottom:0;">
                    <button class="btn-danger-full" onclick="clearChat()">
                        <i class="fa-solid fa-trash-can"></i> Hapus Riwayat Chat
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeSettings()">Batal</button>
                <button class="btn-primary" onclick="saveSettings()">
                    <i class="fa-solid fa-check"></i> Simpan
                </button>
            </div>
        </div>
    </div>

    <!-- Info Modal -->
    <div class="modal" id="infoModal">
        <div class="modal-overlay" onclick="closeInfo()"></div>
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">
                    <i class="fa-solid fa-circle-info"></i>
                    Tentang ZainAI
                </h2>
                <button class="close-btn" onclick="closeInfo()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            
            <div class="modal-body">
                <div class="info-section">
                    <div class="info-logo">
                        <i class="fa-solid fa-robot"></i>
                    </div>
                    <h3>ZainAI Assistant</h3>
                    <p class="version">Version 1.0.0 Beta</p>
                </div>

                <div class="info-item">
                    <i class="fa-solid fa-user-tie"></i>
                    <div>
                        <strong>Developer</strong>
                        <p>Zain Suryo Negoro</p>
                    </div>
                </div>

                <div class="info-item">
                    <i class="fa-solid fa-bolt"></i>
                    <div>
                        <strong>Powered By</strong>
                        <p>Zain-AI - Ultra Fast AI Inference</p>
                    </div>
                </div>

                <div class="info-item">
                    <i class="fa-solid fa-star"></i>
                    <div>
                        <strong>Fitur Utama</strong>
                        <ul class="feature-list">
                            <li>Respons AI super cepat</li>
                            <li>Multiple model AI pilihan</li>
                            <li>Antarmuka responsif mobile</li>
                            <li>Chat history management</li>
                        </ul>
                    </div>
                </div>

              

            </div>
        </div>
    </div>
</section>

<!-- Projects Section -->

<section id="apk-download" class="page-section apk-page">

  <!-- Header -->
  <div class="apk-header">
    <div class="apk-header-glow"></div>
    <div class="apk-header-content">
        <h1 class="apk-title">Download <span class="apk-title-accent">Mod Apk</span></h1>
      <p class="apk-subtitle">Aplikasi premium &amp; mod terpilih — gratis, aman, dan selalu update</p>
      <div class="apk-stats">
        <div class="apk-stat"><span id="apkCount">13</span><small>Aplikasi</small></div>
        <div class="apk-stat-div"></div>
        <div class="apk-stat"><span>100%</span><small>Gratis</small></div>
        <div class="apk-stat-div"></div>
        <div class="apk-stat"><span>MOD</span><small>Premium</small></div>
      </div>
    </div>
  </div>

  <!-- Search -->
  <div class="apk-search-wrap">
    <i class="fas fa-search apk-search-icon"></i>
    <input type="text" id="searchApk" class="apk-search-input" placeholder="Cari aplikasi..." onkeyup="searchAPK()">
    <div class="apk-search-pulse"></div>
  </div>

  <!-- Grid -->
  <div id="apkList" class="apk-grid"></div>

  <!-- Empty state -->
  <div id="apkEmpty" class="apk-empty" style="display:none;">
    <i class="fas fa-search"></i>
    <p>Tidak ada aplikasi ditemukan</p>
  </div>

  <!-- Pagination -->
  <div id="apkPagination" class="apk-pagination"></div>

</section>
<section id="music" class="page-section">

<!-- ============================================================
     HIDDEN LEGACY: elemen lama tetap ada agar script.js tidak error
     Semua disembunyikan, JS lama pakai audio, cd, playBtn dll ini
     ============================================================ -->
<div style="display:none!important;visibility:hidden!important;pointer-events:none!important;position:absolute!important;opacity:0!important;">
  <div class="bg"></div>
  <header class="brand">CyberZain-MUSIC</header>
  <select id="categorySelect">
    <option value="">— Pilih Kategori —</option>
    <option value="😝🤙🏻">Playlist Anda</option>
    <option value="Lagu Terbaru">Lagu Terbaru</option>
    <option value="Sedang Trend">Sedang Trend</option>
  </select>
  <div class="player">
    <button id="menuBtn" class="menu-btn">⋮</button>
    <div id="menuPanel" class="menu-panel">
      <div class="menu-item" id="downloadMusic">Download Music</div>
      <div class="menu-item" id="speedControl">Kecepatan Music</div>
      <div class="menu-item" id="qualityMenuBtn">Kualitas Audio ▸</div>
      <div class="menu-item" id="sleepTimeBtn">Sleep Time ▸</div>
      <div class="menu-item" id="equalizerBtn">Equalizer ▸</div>
      <div class="menu-item" id="contactOwner">Hubungi Pemilik</div>
      <div id="qualitySubmenu" class="submenu">
        <div class="submenu-item" data-quality="96">96 kbps</div>
        <div class="submenu-item" data-quality="128">128 kbps</div>
        <div class="submenu-item" data-quality="192">192 kbps</div>
        <div class="submenu-item" data-quality="320">320 kbps</div>
      </div>
      <div id="sleepSubmenu" class="submenu">
        <div class="submenu-item" data-time="5">5 menit</div>
        <div class="submenu-item" data-time="10">10 menit</div>
        <div class="submenu-item" data-time="15">15 menit</div>
        <div class="submenu-item" data-time="30">30 menit</div>
        <div class="submenu-item" data-time="60">1 jam</div>
      </div>
      <div id="equalizerSubmenu" class="submenu">
        <div class="submenu-item" data-eq="bass">Bass</div>
        <div class="submenu-item" data-eq="treble">Treble</div>
        <div class="submenu-item" data-eq="flat">Flat</div>
      </div>
      <div class="menu-item" id="reportBtn">Report Lagu</div>
    </div>
    <div class="cd-box">
      <div id="cd" class="cd"></div>
    </div>
    <div class="visualizer" id="visualizer">
      <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
      <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
      <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
    </div>
    <div class="yt-info">
      <div class="title-wrap"><h2 id="nowTitle" class="title-scroll">Tidak ada lagu diputar</h2></div>
      <p id="nowArtist">—</p>
    </div>
    <div class="yt-bar" id="seekBar"><div id="progress"></div></div>
    <div class="time-row"><span id="current">0:00</span><span id="duration">0:00</span></div>
    <div class="controls">
      <button id="prevBtn">⏮</button>
      <button id="playBtn">▶</button>
      <button id="nextBtn">⏭</button>
    </div>
    <audio id="audioPlayer" preload="metadata"></audio>
  </div>
  <button class="btn" id="toggleLoop">Mode: Mengganti Music Selanjutnya</button>
  <input type="text" id="searchSong" placeholder="Cari lagu..." oninput="filterSongs()" />
  <div class="playlist" id="playlistBox"></div>
</div>

<!-- ============================================================
     NEW UI — YouTube Music Style (CyberZain Music)
     Semua variabel/function pakai prefix czm_ agar zero konflik
     ============================================================ -->
<!-- VIEW: HOME -->
<div id="czm-home" class="czm-view czm-on">
  <div class="czm-topbar">
    <div class="czm-logo">
      <span class="czm-logo-title czm-rainbow">CyberZain</span><span class="czm-logo-sub">&nbsp;Music</span>
    </div>
    <div class="czm-topbar-right">
      <button class="czm-icon-btn" onclick="czmOpenSearch()" title="Cari"><i class="fa-solid fa-magnifying-glass"></i></button>
    </div>
  </div>
  <!-- Pills + tombol playlist sejajar -->
  <div style="display:flex;align-items:center;border-bottom:1px solid rgba(255,255,255,0.05);background:inherit;">
    <button onclick="czmOpenPlm()" style="flex-shrink:0;background:none;border:none;color:#aaa;font-size:12px;cursor:pointer;padding:10px 10px 10px 16px;-webkit-tap-highlight-color:transparent;transition:color .15s;display:flex;flex-direction:column;align-items:center;gap:3px;" onmouseenter="this.style.color='#00d9ff'" onmouseleave="this.style.color='#aaa'">
      <i class="fa-solid fa-list" style="font-size:16px;"></i>
      <span style="font-size:10px;font-weight:600;white-space:nowrap;">Playlist</span>
    </button>
    <div style="width:1px;height:28px;background:rgba(255,255,255,0.1);flex-shrink:0;"></div>
    <div class="czm-pills" id="czm-pills" style="border-bottom:none;flex:1;">
      <div class="czm-pill active" data-f="all"      onclick="czmMood(this,'all')">Semua</div>
      <div class="czm-pill"        data-f="sad"      onclick="czmMood(this,'sad')">Sedih</div>
      <div class="czm-pill"        data-f="senang"   onclick="czmMood(this,'senang')">Senang</div>
      <div class="czm-pill"        data-f="trending" onclick="czmMood(this,'trending')">Trending</div>
      <div class="czm-pill"        data-f="baru"     onclick="czmMood(this,'baru')">Baru</div>
    </div>
  </div>
  <div class="czm-home-body" id="czm-home-body"></div>
</div>

<!-- VIEW: PLAYER -->
<div id="czm-player" class="czm-view">

  <!-- TOPBAR: chevron kiri + title + dots kanan -->
  <div class="czm-player-topbar">
    <button class="czm-back" onclick="czmGoHome()"><i class="fa-solid fa-chevron-down"></i></button>
    <!-- Normal: DIPUTAR DARI + nama -->
    <div class="czm-topbar-center">
      <div class="czm-topbar-label">Diputar dari</div>
      <div class="czm-topbar-source" id="czm-topbar-source">CyberZain Music</div>
    </div>
    <!-- Saat tab terbuka: thumbnail kecil + judul -->
    <div class="czm-topbar-mini" id="czm-topbar-mini">
      <img class="czm-topbar-mini-art" id="czm-topbar-mini-art" src="" alt="">
      <div class="czm-topbar-mini-info">
        <div class="czm-topbar-mini-title" id="czm-topbar-mini-title">—</div>
        <div class="czm-topbar-mini-artist" id="czm-topbar-mini-artist">—</div>
      </div>
    </div>
    <button class="czm-icon-btn" id="czm-more-toggle" onclick="czmToggleMore()"><i class="fa-solid fa-ellipsis-vertical"></i></button>
    <button class="czm-icon-btn" id="czm-mini-play-btn" onclick="event.stopPropagation();czmToggle()" style="display:none;"><i class="fa-solid fa-play" id="czm-mini-play-ico"></i></button>
  </div>

  <!-- MORE MENU -->
  <div class="czm-more-menu" id="czm-more-menu">
    <div class="czm-mi" onclick="czmDl()"><i class="fa-solid fa-download"></i> Download</div>
    <div class="czm-mi" onclick="czmAddToPlaylistFromMenu()"><i class="fa-solid fa-plus"></i> Simpan ke Playlist</div>
    <div class="czm-mi" onclick="czmToggleLoop()"><i class="fa-solid fa-repeat" id="czm-loop-ico"></i> <span id="czm-loop-lbl">Loop: Off</span></div>
    <div class="czm-mi" onclick="czmSleep()"><i class="fa-solid fa-moon"></i> Sleep Timer</div>
    <div class="czm-mi" onclick="czmSpeedSheet()"><i class="fa-solid fa-gauge-high"></i> Kecepatan</div>
    <div class="czm-mi" onclick="czmQualitySheet()"><i class="fa-solid fa-sliders"></i> Kualitas Audio</div>
    <div class="czm-mi" onclick="czmReportSong()"><i class="fa-solid fa-flag"></i> Laporkan</div>
  </div>

  <!-- NEXT HEADER: Diputar dari + Simpan + Filter Chips — tampil hanya saat tab BERIKUTNYA aktif -->
  <div id="czm-next-header" style="display:none; background:#0f2035; padding:10px 20px 0; flex-shrink:0; border-bottom:1px solid rgba(255,255,255,0.06);">
    <div class="czm-from-row">
      <div>
        <div class="czm-from-label">Diputar dari</div>
        <div class="czm-from-name" id="czm-from-name">CyberZain Music</div>
      </div>
      <button class="czm-save-btn" onclick="czmAddToPlaylistFromMenu()"><i class="fa-solid fa-list-ul"></i> Simpan</button>
    </div>
    <div class="czm-filter-bar" id="czm-filter-bar">
      <button class="czm-filter-chip active" data-filter="all"      onclick="czmSetFilter(this,'all')">All</button>
      <button class="czm-filter-chip"         data-filter="populer" onclick="czmSetFilter(this,'populer')">Populer</button>
      <button class="czm-filter-chip"         data-filter="temukan" onclick="czmSetFilter(this,'temukan')">Temukan</button>
      <button class="czm-filter-chip"         data-filter="pesta"   onclick="czmSetFilter(this,'pesta')">Pesta</button>
      <button class="czm-filter-chip"         data-filter="romansa" onclick="czmSetFilter(this,'romansa')">Romansa</button>
    </div>
  </div>

  <!-- SCROLL AREA: semua konten yang bisa di-scroll -->
  <div class="czm-scroll-area" id="czm-scroll-area">

    <!-- FULL VIEW body (album art + controls) -->
    <div class="czm-player-body">
      <div class="czm-full-view" id="czm-full-view">
        <div class="czm-art-wrap" id="czm-art-wrap">
        <img id="czm-art" src="" alt="cover">
        <video id="czm-video" playsinline loop style="display:none;width:100%;height:100%;object-fit:cover;"></video>
      </div>
        <div class="czm-info-row">
          <div class="czm-info-text">
            <div class="czm-title-clip"><span class="czm-stitle" id="czm-stitle">—</span></div>
            <div class="czm-sartist" id="czm-sartist">—</div>
          </div>
        </div>
        <!-- Action pills: Like, Dislike, Simpan, Share, Download -->
        <div class="czm-action-row">
          <button class="czm-action-pill" id="czm-like-btn" onclick="czmToggleLike()">
            <i class="fa-regular fa-thumbs-up"></i> Suka
          </button>
          <button class="czm-action-pill" id="czm-dislike-btn" onclick="czmToggleDislike()">
            <i class="fa-regular fa-thumbs-down"></i> Tidak Suka
          </button>
          <button class="czm-action-pill" onclick="czmAddToPlaylistFromMenu()">
            <i class="fa-solid fa-list-ul"></i> Simpan
          </button>
          <button class="czm-action-pill" onclick="czmBsShare()">
            <i class="fa-solid fa-share-nodes"></i> Bagikan
          </button>
          <button class="czm-action-pill" onclick="czmDl()">
            <i class="fa-solid fa-download"></i> Download
          </button>
        </div>
        <div class="czm-seekbar-wrap">
          <div class="czm-seekbar" id="czm-seekbar" onclick="czmSeek(event)">
            <div id="czm-prog"></div>
            <div class="czm-seek-thumb" id="czm-seek-thumb"></div>
          </div>
          <div class="czm-times"><span id="czm-cur">0:00</span><span id="czm-dur">0:00</span></div>
        </div>
        <div class="czm-ctrl">
          <button class="czm-cbtn" id="czm-shuffle-btn" onclick="czmToggleShuffle()"><i class="fa-solid fa-shuffle"></i></button>
          <button class="czm-cbtn" onclick="czmPrev()"><i class="fa-solid fa-backward-step"></i></button>
          <button class="czm-playbtn" id="czm-playbtn" onclick="czmToggle()"><i class="fa-solid fa-play" id="czm-play-ico"></i></button>
          <button class="czm-cbtn" onclick="czmNext()"><i class="fa-solid fa-forward-step"></i></button>
          <button class="czm-cbtn" id="czm-repeat-btn" onclick="czmToggleLoop()"><i class="fa-solid fa-repeat" id="czm-loop-ico2"></i></button>
        </div>
        <div class="czm-vis" id="czm-vis">
          <div class="czm-vbar"></div><div class="czm-vbar"></div><div class="czm-vbar"></div>
          <div class="czm-vbar"></div><div class="czm-vbar"></div><div class="czm-vbar"></div>
          <div class="czm-vbar"></div><div class="czm-vbar"></div><div class="czm-vbar"></div>
          <div class="czm-vbar"></div><div class="czm-vbar"></div><div class="czm-vbar"></div>
          <div class="czm-vbar"></div><div class="czm-vbar"></div><div class="czm-vbar"></div>
        </div>
      </div>
    </div>

    <!-- COLLAPSED VIEW -->
    <div class="czm-collapsed-view" id="czm-collapsed-view">

      <!-- Tab BERIKUTNYA -->
      <div class="czm-tab-content czm-tab-hidden" id="czm-tab-content-next">
        <div id="czm-pl-box"></div>
      </div>

      <!-- Tab TERKAIT -->
      <div class="czm-tab-content czm-tab-hidden" id="czm-tab-content-related">
        <div id="czm-related-box">
          <div style="text-align:center;color:#555;padding:48px 0;font-size:14px;">Memuat rekomendasi...</div>
        </div>
      </div>

    </div><!-- end czm-collapsed-view -->

  </div><!-- end czm-scroll-area -->

  <!-- TAB BAR: pinned di bawah player (flex child, bukan fixed) -->
  <div class="czm-tab-bar" id="czm-tab-bar">
    <button class="czm-tab" id="czm-tab-next" onclick="czmSwitchTab('next')">BERIKUTNYA</button>
    <button class="czm-tab" id="czm-tab-related" onclick="czmSwitchTab('related')">TERKAIT <i class="fa-solid fa-magnifying-glass" id="czm-related-search-icon" style="font-size:11px;margin-left:4px;opacity:0.6;display:none;" onclick="event.stopPropagation();czmOpenRelatedSearch()"></i></button>
  </div>

</div>

<!-- RELATED SEARCH OVERLAY: fullscreen khusus tab TERKAIT -->
<div id="czm-rel-search-ov" style="display:none;position:fixed;inset:0;background:#0f2035;z-index:10035;flex-direction:column;">
  <!-- Topbar search -->
  <div style="display:flex;align-items:center;gap:12px;padding:14px 14px 14px;background:#0f2035;border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;">
    <button onclick="czmCloseRelatedSearch()" style="background:none;border:none;color:#fff;font-size:20px;cursor:pointer;padding:4px;flex-shrink:0;">
      <i class="fa-solid fa-arrow-left"></i>
    </button>
    <div style="flex:1;display:flex;align-items:center;background:#152840;border-radius:24px;padding:10px 16px;gap:10px;">
      <i class="fa-solid fa-magnifying-glass" style="color:#777;font-size:14px;flex-shrink:0;"></i>
      <input id="czm-rel-search-inp" type="text" placeholder="Cari lagu di rekomendasi..."
        style="background:none;border:none;color:#fff;font-size:15px;outline:none;width:100%;font-family:inherit;"
        oninput="czmDoRelatedSearch(this.value)"
        autofocus>
      <button id="czm-rel-search-clear" onclick="document.getElementById('czm-rel-search-inp').value='';czmDoRelatedSearch('');this.style.display='none';"
        style="display:none;background:none;border:none;color:#666;font-size:18px;cursor:pointer;padding:0;flex-shrink:0;">✕</button>
    </div>
  </div>
  <!-- Hasil search -->
  <div id="czm-rel-search-res" style="flex:1;overflow-y:auto;padding:8px 0;">
    <div style="text-align:center;color:#444;padding:60px 0;font-size:14px;">
      <i class="fa-solid fa-magnifying-glass" style="font-size:32px;margin-bottom:12px;display:block;opacity:0.3;"></i>
      Ketik untuk mencari lagu
    </div>
  </div>
</div>

<!-- SEARCH OVERLAY -->
<div class="czm-search-ov" id="czm-search-ov">
  <div class="czm-search-bar">
    <button class="czm-icon-btn" onclick="czmCloseSearch()"><i class="fa-solid fa-arrow-left"></i></button>
    <div class="czm-search-input-wrap">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input type="text" id="czm-search-inp" placeholder="Cari lagu, artis..." oninput="czmDoSearch(this.value)">
    </div>
  </div>
  <div class="czm-search-res" id="czm-search-res"></div>
</div>

<!-- NOW PLAYING BAR (dipindah ke body level) -->

<!-- BOTTOM SHEET -->
<div class="czm-bs-ov"   id="czm-bs-ov"   onclick="czmCloseBs()"></div>
<div class="czm-bs-menu" id="czm-bs-menu">
  <div class="czm-bs-handle"><span></span></div>
  <div class="czm-bs-head">
    <img id="czm-bs-img" src="" style="width:48px;height:48px;border-radius:6px;object-fit:cover;flex-shrink:0;">
    <div style="flex:1;min-width:0;">
      <div id="czm-bs-title"  style="font-size:14px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#fff;"></div>
      <div id="czm-bs-artist" style="font-size:12px;color:#aaa;margin-top:2px;"></div>
    </div>
    <button class="czm-icon-btn" onclick="czmCloseBs()"><i class="fa-solid fa-xmark"></i></button>
  </div>
  <div class="czm-bs-actions">
    <div class="czm-bs-act" onclick="czmBsQueueNext()">
      <div class="czm-bs-act-ico"><i class="fa-solid fa-list-check"></i></div>
      <span class="czm-bs-act-lbl">Putar setelah<br>ini</span>
    </div>
    <div class="czm-bs-act" onclick="czmBsAddPl()">
      <div class="czm-bs-act-ico"><i class="fa-solid fa-list-ul"></i></div>
      <span class="czm-bs-act-lbl">Simpan ke<br>playlist</span>
    </div>
    <div class="czm-bs-act" onclick="czmBsShare()">
      <div class="czm-bs-act-ico"><i class="fa-solid fa-share-nodes"></i></div>
      <span class="czm-bs-act-lbl">Bagikan</span>
    </div>
  </div>
  <div class="czm-bs-list">
    <div class="czm-bsi" onclick="czmBsPlay()"><i class="fa-solid fa-play" style="width:20px;color:#777;"></i> Putar</div>
    <div class="czm-bsi" onclick="czmBsDl()"><i class="fa-solid fa-download" style="width:20px;color:#777;"></i> Download</div>
    <div class="czm-bsi" onclick="czmBsLike()" id="czm-bs-like-row">
      <i class="fa-regular fa-heart" id="czm-bs-like-ico" style="width:20px;color:#777;"></i>
      <span id="czm-bs-like-lbl">Simpan ke galeri</span>
    </div>
    <div class="czm-bsi" onclick="czmBsReport()"><i class="fa-solid fa-flag" style="width:20px;color:#777;"></i> Laporkan</div>
  </div>
</div>

</section>

<!-- Kirim Pesan Section -->


  <div id="apkModal" class="apk-modal-overlay" style="display:none;" onclick="if(event.target===this)closeInfo()">
